<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NotesShowcase.ViewModels"
             x:Class="NotesShowcase.Views.NoteFormView"
             x:DataType="vm:NoteFormVM">

    <!--
      Editing note (plan §5.a, scenario §6.2): NoteModel is a `record` so
      Draft.Title/Body/Starred are immutable per-property. Two-way text binding
      onto record fields is not viable as-is; this view exposes the draft
      one-way for display, plus the tag input / Save / Revert commands which
      are mutation-safe (the VM owns the rebuild via `Draft = Draft with {...}`).
      Surfacing per-field setters on NoteFormVM is a Phase 7 polish item; the
      smoke test, Approve/Deny commands, and the capability action bar all work
      against the current surface.
    -->
    <Grid Margin="12" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto">
        <TextBlock Grid.Row="0"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource SubtleTextBrush}"
                   Text="Note" Margin="0,0,0,8" />

        <!-- Title (row 1) -->
        <TextBox Grid.Row="1"
                 Watermark="Title"
                 Text="{Binding Draft.Title, Mode=OneWay}"
                 IsReadOnly="True"
                 Margin="0,0,0,8" />

        <!-- Tags (row 2): chips + input -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Spacing="4" Margin="0,0,0,8">
            <ItemsControl ItemsSource="{Binding Draft.Tags}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BorderBrush}"
                                CornerRadius="10"
                                Padding="8,2"
                                Margin="2">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="{Binding}" />
                                <Button Content="×"
                                        Padding="2,-2"
                                        Background="Transparent"
                                        Command="{Binding $parent[UserControl].((vm:NoteFormVM)DataContext).RemoveTagCommand}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBox Watermark="add tag"
                         Text="{Binding TagDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="160" />
                <Button Content="+" Command="{Binding AddTagCommand}" />
            </StackPanel>
        </StackPanel>

        <!-- Starred (row 3) -->
        <CheckBox Grid.Row="3"
                  Content="Starred"
                  IsChecked="{Binding Draft.Starred, Mode=OneWay}"
                  IsEnabled="False"
                  Margin="0,0,0,8" />

        <!-- Body (row 4) -->
        <TextBox Grid.Row="4"
                 Watermark="Body"
                 Text="{Binding Draft.Body, Mode=OneWay}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalContentAlignment="Top" />

        <!-- Dirty indicator (row 5) -->
        <TextBlock Grid.Row="5"
                   Foreground="{StaticResource SubtleTextBrush}"
                   Text="●"
                   IsVisible="{Binding IsDirty}"
                   Margin="0,8,0,0" />

        <!-- Action buttons (row 6) -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
            <Button Content="Save"    Command="{Binding ApproveCommand}" />
            <Button Content="Revert"  Command="{Binding DenyCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
