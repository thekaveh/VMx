<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NotesShowcase.ViewModels"
             x:Class="NotesShowcase.Views.StatusBarView"
             x:DataType="vm:StatusBarVM">
    <!--
      Bindings target the ``Bindable`` sidecars (BindableDerived<T>) so the
      slots live-update on every recompute. The raw DerivedProperty<T> on the
      VM does not raise INPC for ``.Value`` — see Phase 5.a binding gap #3.
    -->
    <StackPanel Orientation="Horizontal" Spacing="16">
        <TextBlock Foreground="{StaticResource SubtleTextBrush}"
                   Text="{Binding NoteCountTextBindable.Value}" />
        <TextBlock Foreground="{StaticResource SubtleTextBrush}"
                   Text="·" />
        <TextBlock Foreground="{StaticResource SubtleTextBrush}"
                   Text="{Binding StarredTextBindable.Value}" />
        <TextBlock Foreground="{StaticResource SubtleTextBrush}"
                   Text="·" />
        <TextBlock Foreground="{StaticResource TextBrush}"
                   Text="{Binding EditingTextBindable.Value}" />
    </StackPanel>
</UserControl>
