<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NotesShowcase.ViewModels"
             x:Class="NotesShowcase.Views.CapabilityActionsView"
             x:DataType="vm:CapabilityActionsVM">
    <!--
      Binds to ``ActionsBindable`` (BindableDerived<IReadOnlyList<ActionVM>>)
      so the bar repopulates whenever focus shifts. The raw ``Actions``
      DerivedProperty does not raise INPC — see Phase 5.a binding gap #3.
    -->
    <StackPanel Orientation="Horizontal" Spacing="6">
        <Button Content="+ Note"
                AutomationProperties.Name="Add note"
                Command="{Binding AddNoteCommand}" />
        <ItemsControl ItemsSource="{Binding ActionsBindable.Value}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Spacing="6" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Label}"
                            Command="{Binding Command}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
