<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NotesShowcase.ViewModels"
             x:Class="NotesShowcase.Views.NotebooksTreeView"
             x:DataType="vm:NotebooksRootVM">

    <!--
      Tree rendering note (plan §5.a / scenario §6.2): NotebookVM does not expose
      a `Children` collection; the parent/child relation lives on NotebooksRootVM
      via ChildrenOf(parent). Until a Children accessor lands on NotebookVM, the
      tree binds to `Roots` only — sufficient for the spec's "4 root notebooks"
      smoke test and the toolbar's "Add notebook (root)" flow. Nested-notebook
      navigation is a Phase 7 polish item.
    -->
    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0"
                   Margin="12,12,12,6"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource SubtleTextBrush}"
                   Text="Notebooks" />
        <TreeView Grid.Row="1"
                  x:Name="NotebooksTree"
                  Background="Transparent"
                  Foreground="{StaticResource TextBrush}"
                  ItemsSource="{Binding Roots}"
                  SelectedItem="{Binding Current, Mode=TwoWay}">
            <TreeView.ItemTemplate>
                <TreeDataTemplate>
                    <TextBlock Text="{Binding NotebookName}"
                               Padding="4,2" />
                </TreeDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
