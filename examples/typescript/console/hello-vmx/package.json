{
  "name": "hello-vmx",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal Node script demonstrating the VMx TypeScript library.",
  "type": "module",
  "scripts": {
    "build:vmx": "npm --prefix ../../../../langs/typescript ci && npm --prefix ../../../../langs/typescript run build",
    "prestart": "npm run build:vmx",
    "start": "tsx index.ts",
    "pretypecheck": "npm run build:vmx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@thekaveh/vmx": "file:../../../../langs/typescript",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  }
}
