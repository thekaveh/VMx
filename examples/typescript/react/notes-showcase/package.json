{
  "name": "notes-showcase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:vmx": "npm --prefix ../../../../langs/typescript ci && npm --prefix ../../../../langs/typescript run build",
    "predev": "npm run build:vmx",
    "dev": "vite",
    "prebuild": "npm run build:vmx",
    "build": "tsc --noEmit && vite build",
    "pretypecheck": "npm run build:vmx",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "pretest": "npm run build:vmx",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@thekaveh/vmx": "file:../../../../langs/typescript",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@eslint/js": "^9.39.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
