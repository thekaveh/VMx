{
  "name": "notes-showcase",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:vmx": "npm --prefix ../../../../langs/typescript ci && npm --prefix ../../../../langs/typescript run build",
    "predev": "npm run build:vmx",
    "dev": "vite",
    "prebuild": "npm run build:vmx",
    "build": "tsc --noEmit && vite build",
    "pretypecheck": "npm run build:vmx",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "pretest": "npm run build:vmx",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@thekaveh/vmx": "file:../../../../langs/typescript",
    "react": "^19.2.7",
    "react-dom": "^19.2.8",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.8",
    "axe-core": "^4.12.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  }
}
