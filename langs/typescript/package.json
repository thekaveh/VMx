{
  "name": "vmx",
  "version": "2.1.0",
  "description": "Hierarchical lifecycle-aware MVVM viewmodel framework",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./notifications": {
      "types": "./dist/notifications.d.ts",
      "import": "./dist/notifications.js",
      "require": "./dist/notifications.cjs"
    }
  },
  "files": [
    "dist",
    "src/fixtures"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "sync-fixtures": "node scripts/sync-fixtures.mjs",
    "check-version-sync": "node scripts/check-version-sync.mjs",
    "prebuild": "npm run sync-fixtures && npm run check-version-sync",
    "prepack": "npm run sync-fixtures && npm run check-version-sync && npm run build"
  },
  "keywords": [
    "mvvm",
    "viewmodel",
    "reactive",
    "rxjs"
  ],
  "author": "Kaveh Razavi",
  "license": "MIT",
  "homepage": "https://github.com/thekaveh/VMx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thekaveh/VMx.git",
    "directory": "langs/typescript"
  },
  "bugs": {
    "url": "https://github.com/thekaveh/VMx/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
