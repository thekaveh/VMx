{
  "name": "@thekaveh/vmx",
  "version": "2.4.0",
  "description": "Hierarchical lifecycle-aware MVVM viewmodel framework",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./notifications": {
      "import": {
        "types": "./dist/notifications.d.ts",
        "default": "./dist/notifications.js"
      },
      "require": {
        "types": "./dist/notifications.d.cts",
        "default": "./dist/notifications.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src/fixtures"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.tests.json --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "sync-fixtures": "node scripts/sync-fixtures.mjs",
    "check-version-sync": "node scripts/check-version-sync.mjs",
    "prebuild": "npm run sync-fixtures && npm run check-version-sync",
    "prepack": "npm run sync-fixtures && npm run check-version-sync && npm run build"
  },
  "keywords": [
    "mvvm",
    "viewmodel",
    "reactive",
    "rxjs"
  ],
  "author": "Kaveh Razavi",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/thekaveh/VMx#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thekaveh/VMx.git",
    "directory": "langs/typescript"
  },
  "bugs": {
    "url": "https://github.com/thekaveh/VMx/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "rxjs": "^7.8.0"
  },
  "peerDependenciesMeta": {
    "rxjs": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "jsdom": "^24.0.0",
    "rxjs": "^7.8.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.4"
  }
}
