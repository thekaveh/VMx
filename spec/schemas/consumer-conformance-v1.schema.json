{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:vmx:consumer-conformance:1.0.0",
  "$comment": "Non-normative VMx consumer-adapter contract. This schema executes consumer-provided operations and assertions; it does not define a VMx viewmodel or make a consumer YAML dialect normative.",
  "title": "VMx consumer conformance adapter suite v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema-version", "suite", "cases"],
  "properties": {
    "$schema-version": {
      "const": "1.0.0"
    },
    "suite": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "fixture": {
      "$ref": "#/$defs/jsonValue"
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "jsonValue": {
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/jsonValue"
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "steps"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "fixture": {
          "$ref": "#/$defs/jsonValue"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/step"
          }
        }
      }
    },
    "step": {
      "oneOf": [
        { "$ref": "#/$defs/invokeStep" },
        { "$ref": "#/$defs/assertStateStep" },
        { "$ref": "#/$defs/assertMessagesStep" }
      ]
    },
    "invokeStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "operation"],
      "properties": {
        "kind": {
          "const": "invoke"
        },
        "operation": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      }
    },
    "assertStateStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path", "equals"],
      "properties": {
        "kind": {
          "const": "assert-state"
        },
        "path": {
          "type": "string",
          "pattern": "^(|(?:/(?:[^~/]|~[01])*)+)$"
        },
        "equals": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "assertMessagesStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "equals"],
      "properties": {
        "kind": {
          "const": "assert-messages"
        },
        "equals": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonObject"
          }
        }
      }
    }
  }
}
